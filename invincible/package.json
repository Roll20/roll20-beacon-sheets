{
  "name": "@mperes/beacon-sheet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "vite": "node --disable-warning=DEP0205 node_modules/vite/bin/vite.js",
    "generate-effect-paths": "npx vite-node scripts/generate-effect-paths.ts",
    "generate-svg-sprites": "npx vite-node scripts/generate-svg-sprites.ts",
    "build-schema": "npx vite-node scripts/build-schema.ts",
    "predev": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "dev": "npm run vite",
    "sandbox-server": "npm run vite -- --port 7620 --mode staging",
    "sandbox": "run-s build-scss sandbox-server",
    "prebuild": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "build": "run-s build-scss build-only",
    "preview": "npm run vite -- preview",
    "pretest:unit": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "test:unit": "vitest --no-watch",
    "pretest:unit:watch": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "test:unit:watch": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:local": "start-server-and-test 'npm run dev -- --port 4173' http://localhost:4173 'cypress run --e2e'",
    "test:e2e:open:local": "start-server-and-test 'npm run dev -- --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "npm run vite -- build",
    "build-scss": "npx @tailwindcss/cli -i ./src/rolltemplates/styles/host.css -o ./public/host.css --minify",
    "watch-scss": "npx @tailwindcss/cli -i ./src/rolltemplates/styles/host.css -o ./public/host.css --watch",
    "pretype-check": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "preci-check": "npm run generate-effect-paths && npm run generate-svg-sprites",
    "ci-check": "npm run format && npm run lint && npm run type-check && npm run test:unit && npm run test:e2e:local"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@roll20-official/beacon-sdk": "^0.1.17",
    "codemirror": "^6.0.2",
    "codemirror-json-schema": "^0.8.1",
    "dice-notation": "^0.0.3",
    "dompurify": "^3.4.5",
    "floating-vue": "^5.2.2",
    "handlebars": "^4.7.9",
    "jsonpath": "^1.3.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "mathjs": "^15.2.0",
    "overlayscrollbars-vue": "^0.5.10",
    "pinia": "^3.0.4",
    "uuid": "^14.0.0",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.34",
    "vue-codemirror": "^6.1.1",
    "vue-color": "^3.3.3",
    "vue-component-library": "^0.0.8",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/vue": "^8.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/jsonpath": "^0.2.4",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.15.0",
    "eslint": "^10.3.0",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.6",
    "vitest-dom": "^0.1.1",
    "vue-tsc": "^3.2.8"
  },
  "overrides": {
    "glob": "^13.0.0"
  }
}
